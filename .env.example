# ==============================================================================
# ШАБЛОН КОНФИГУРАЦИИ (СКОПИРУЙТЕ В .env И ЗАПОЛНИТЕ)
# ==============================================================================

# Имя проекта Docker Compose
COMPOSE_PROJECT_NAME=vless-reality

# ==============================================================================
# НАСТРОЙКИ ПАНЕЛИ 3X-UI
# ==============================================================================
# Порт панели (10000-65000)
PANEL_PORT=

# Скрытый путь к панели (16 символов)
PANEL_PATH=

# Учётные данные
PANEL_USERNAME=
PANEL_PASSWORD=

# ==============================================================================
# НАСТРОЙКИ XRAY
# ==============================================================================
XRAY_LOG_LEVEL=warning
VLESS_PORT=443
UUID=

# ==============================================================================
# НАСТРОЙКИ REALITY
# ==============================================================================
REALITY_DEST=www.microsoft.com:443
REALITY_SNI=www.microsoft.com
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=

# ==============================================================================
# БЕЗОПАСНОСТЬ
# ==============================================================================
FAIL2BAN_ENABLED=true
FAIL2BAN_MAX_RETRY=3
FAIL2BAN_BANTIME=86400
FAIL2BAN_FINDTIME=600

# ==============================================================================
# СЕРТИФИКАТЫ
# ==============================================================================
CERT_EMAIL=
DOMAIN=

# ==============================================================================
# PORTAINER
# ==============================================================================
PORTAINER_PORT=9000
PORTAINER_USERNAME=
PORTAINER_PASSWORD=
PORTAINER_HASHED_PASSWORD=

# ==============================================================================
# СИСТЕМНЫЕ НАСТРОЙКИ
# ==============================================================================
TZ=Europe/Samara