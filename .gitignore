
# Файл с переменными окружения (содержит пароли, ключи, UUID)
.env
.env.backup*
.env.local

# Приватные ключи и сертификаты
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
!config/nginx/*.crt

# Ключи Reality (если хранятся отдельно)
reality_*.key
reality_*.pem

# SSH ключи (если хранятся в проекте)
id_rsa
id_ed25519
*.pub
!scripts/authorized_keys.example

# ==============================================================================
# ДАННЫЕ КОНТЕЙНЕРОВ И ПРИЛОЖЕНИЙ
# ==============================================================================

# Основная директория с данными (базы, конфиги, логи)
data/
data/**
!data/.gitkeep

# 3X-UI данные
data/3x-ui/
data/3x-ui/db/
data/3x-ui/*.db
data/3x-ui/*.db-shm
data/3x-ui/*.db-wal

# Xray данные
data/xray/
data/xray/config.json

# Portainer данные
data/portainer/
data/portainer/public/
data/portainer/compose*

# Сертификаты (Let's Encrypt и self-signed)
data/cert/
data/cert/*.pem
data/cert/*.key
data/cert/*.crt

# ==============================================================================
# ЛОГИ
# ==============================================================================

# Все логи (генерируются运行时)
*.log
logs/
logs/**
!logs/.gitkeep

# Логи Xray
data/logs/
data/logs/xray/
data/logs/nginx/

# Логи Docker
docker-logs/

# Системные логи
*.syslog
auth.log
syslog

# ==============================================================================
# РЕЗЕРВНЫЕ КОПИИ
# ==============================================================================

# Директория с бэкапами
backups/
backups/**
!backups/.gitkeep

# Временные файлы бэкапов
*.tar.gz
*.tar.bz2
*.zip
*.bak
*.backup
*.backup.*

# ==============================================================================
# ВРЕМЕННЫЕ И КЭШ ФАЙЛЫ
# ==============================================================================

# Временные файлы
*.tmp
*.temp
*.swp
*.swo
*~
.#*

# Кэш
.cache/
.cache/**
__pycache__/
*.py[cod]
*$py.class

# Node.js (если используется для веб-интерфейса)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (для скриптов)
*.py[cod]
__pycache__/
.venv/
venv/
ENV/

# ==============================================================================
# СПЕЦИФИЧНЫЕ ФАЙЛЫ ОПЕРАЦИОННЫХ СИСТЕМ
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.cache/

# ==============================================================================
# IDE И РЕДАКТОРЫ
# ==============================================================================

# Visual Studio Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*
.\#*

# ==============================================================================
# DOCKER СПЕЦИФИЧНЫЕ ФАЙЛЫ
# ==============================================================================

# Docker volumes (если создаются локально)
docker-volumes/

# Docker compose overrides (локальные настройки)
docker-compose.override.yml
docker-compose.local.yml

# Docker build cache
.docker/

# ==============================================================================
# КЛИЕНТСКИЕ КОНФИГУРАЦИИ
# ==============================================================================

# Конфиги клиентов (содержат ключи)
client-configs/
client-configs/*.json
client-configs/*.yaml
client-configs/*.yml

# QR коды (содержат ключи)
qr-codes/
*.png
!README-images/*.png

# ==============================================================================
# ТЕСТОВЫЕ ФАЙЛЫ
# ==============================================================================

# Тестовые конфигурации
test-configs/
test-*.json
test-*.yml

# Coverage reports
coverage/
*.cover
.hypothesis/

# ==============================================================================
# ДОКУМЕНТАЦИЯ И ИЗОБРАЖЕНИЯ (опционально)
# ==============================================================================

# Временные документы
docs/temp/
docs/drafts/

# Большие файлы
*.iso
*.img
*.vmdk
*.qcow2

# ==============================================================================
# СЕТЕВЫЕ И БЕЗОПАСНОСТНЫЕ ФАЙЛЫ
# ==============================================================================

# Firewall правила (если экспортируются)
iptables.rules
ufw.rules
firewalld-rules.xml

# Fail2Ban конфигурации (если кастомные)
fail2ban/
!scripts/fail2ban/

# ==============================================================================
# АВТОМАТИЗАЦИЯ И CI/CD
# ==============================================================================

# Ansible vault (зашифрованные переменные)
*.vault
ansible/vault/

# Terraform (если используется)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# GitHub Actions секреты (локальные)
.github/secrets/

# ==============================================================================
# РАЗНОЕ
# ==============================================================================

# Файлы с результатами тестов
test-results/
*.result

# Файлы с ошибками
*.error
*.err

# Файлы с выводом консоли
*.out
console.log

# Временные скрипты
temp-scripts/
debug-*.sh

